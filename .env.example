# Скопируйте в `.env` и при необходимости поправьте значения.
# Файл `.env` не коммитится (см. `.gitignore`).

# PostgreSQL (контейнер `neo_postgres` в docker-compose)
# Внутри Docker-сети приложения подключаются к хосту `postgres`, порт 5432.
# С хоста машины (DBeaver, локальный Python) используйте localhost и порт из POSTGRES_PORT ниже.
POSTGRES_DB=neo_invest
POSTGRES_USER=neo
POSTGRES_PASSWORD=neo_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# MOEX ISS API
MOEX_BASE_URL=https://iss.moex.com/iss
MOEX_TIMEOUT_SEC=20
MOEX_POLL_SECONDS=10
MOEX_TICKERS=SBER,GAZP,LKOH,YDEX,VTBR,ROSN,NVTK,TATN,GMKN,NLMK

# Airflow (docker-compose): UID пользователя в контейнере (на macOS часто 50000)
AIRFLOW_UID=50000
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
